			</Layer>
		</Layers>
		<Frames>
			<Button name="$parent_RollButton" inherits="GameMenuButtonTemplate" text="Разрол">
				<Size><AbsDimension x="60" y="22"/></Size>
				<Anchors>
					<Anchor point="RIGHT">
						<Offset><AbsDimension x="-155" y="0"/></Offset>
					</Anchor>
				</Anchors>
			</Button>
			<Button name="$parent_GiveButton" inherits="GameMenuButtonTemplate" text="Выдать">
				<Size><AbsDimension x="60" y="22"/></Size>
