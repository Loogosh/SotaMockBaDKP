			<Anchor point="TOPLEFT">
				<Offset><AbsDimension x="20" y="-60"/></Offset>
			</Anchor>
		</Anchors>
		<Layers>
			<Layer level="BACKGROUND">
				<Texture name="$parentBg">
					<Color r="0.1" g="0.1" b="0.1" a="0.5"/>
