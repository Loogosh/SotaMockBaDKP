				<Anchors>
					<Anchor point="RIGHT">
						<Offset><AbsDimension x="-5" y="0"/></Offset>
					</Anchor>
				</Anchors>
			</Button>
		</Frames>
	<Scripts>
		<OnEnter>
			if this.itemId and this.itemId ~= 0 then
				GameTooltip:SetOwner(this, "ANCHOR_RIGHT");
				GameTooltip:SetHyperlink("item:"..this.itemId..":0:0:0");
				GameTooltip:Show();
			end
		</OnEnter>
		<OnLeave>
			GameTooltip:Hide();
		</OnLeave>
	</Scripts>
